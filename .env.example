# then paste the profile ID here.
BROWSER_USE_PROFILE_ID=

AGENTMAIL_API_KEY=
AGENTMAIL_FROM=
AGENTMAIL_INBOX_ID=

SUPERMEMORY_API_KEY=
SUPERMEMORY_USER_ID=demo-user
SUPERMEMORY_PROJECT_ID=gofer

MOSS_API_KEY=
SPONGE_API_KEY=
