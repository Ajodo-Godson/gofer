# Demo recipient for SMS/email/call actions once real integrations are enabled.
DEMO_USER_PHONE=
DEMO_USER_EMAIL=
DEMO_TEST_RECIPIENT_PHONE=
DEMO_TEST_RECIPIENT_EMAIL=
DEMO_AGENTPHONE_CALL_TARGET=

# Safety toggles for live actions.
DEMO_MODE=true
ALLOW_BROWSER_USE_LIVE_TASK=false
ALLOW_REAL_SMS_SEND=false
ALLOW_REAL_EMAIL_SEND=false
ALLOW_REAL_RESTAURANT_CALLS=false
